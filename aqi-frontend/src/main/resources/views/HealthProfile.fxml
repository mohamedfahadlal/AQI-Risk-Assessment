<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.aqi.controllers.HealthProfileController">

    <VBox alignment="CENTER"
          spacing="30"
          styleClass="card"
          maxWidth="560">

        <Label text="Health Profile"
               styleClass="title"/>

        <GridPane hgap="20" vgap="18">

            <columnConstraints>
                <ColumnConstraints minWidth="160" />
                <ColumnConstraints prefWidth="220" />
                <ColumnConstraints prefWidth="100" />
            </columnConstraints>

            <Label text="Date of Birth:"
                   styleClass="form-label"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>

            <HBox spacing="8" alignment="CENTER_LEFT"
                  GridPane.rowIndex="0" GridPane.columnIndex="1">
                <TextField fx:id="dobField"
                           prefWidth="175"
                           promptText="DD/MM/YYYY"
                           editable="false"
                           style="-fx-background-radius: 6;"/>
                <Button fx:id="calendarBtn"
                        text="📅"
                        style="-fx-cursor: hand; -fx-background-color: transparent; -fx-font-size: 16px; -fx-padding: 0;"/>
            </HBox>

            <Label fx:id="ageDisplayLabel"
                   text=""
                   styleClass="age-label"
                   GridPane.rowIndex="0" GridPane.columnIndex="2"/>

            <Label text="Gender:"
                   styleClass="form-label"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="genderCombo"
                      prefWidth="220"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Location:"
                   styleClass="form-label"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="locationField"
                       promptText="Enter city"
                       prefWidth="220"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Breathing Condition:"
                   styleClass="form-label"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ComboBox fx:id="breathingCombo"
                      prefWidth="220"
                      GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label fx:id="conditionLabel"
                   text="Condition Type:"
                   styleClass="form-label"
                   GridPane.rowIndex="4" GridPane.columnIndex="0"
                   visible="false"
                   managed="false"/>
            <VBox fx:id="conditionBox"
                  spacing="8"
                  GridPane.rowIndex="4" GridPane.columnIndex="1"
                  visible="false"
                  managed="false">
                <CheckBox fx:id="asthmaCheck"
                          text="Asthma"
                          styleClass="custom-check"/>
                <CheckBox fx:id="copdCheck"
                          text="COPD"
                          styleClass="custom-check"/>
                <CheckBox fx:id="bronchitisCheck"
                          text="Chronic Bronchitis"
                          styleClass="custom-check"/>
                <CheckBox fx:id="otherBreathingCheck"
                          text="Other"
                          styleClass="custom-check"/>
            </VBox>

            <Label text="Smoker:"
                   styleClass="form-label"
                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <CheckBox fx:id="smokerCheck"
                      text="Yes"
                      styleClass="custom-check"
                      GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Allergies:"
                   styleClass="form-label"
                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <CheckBox fx:id="allergicCheck"
                      text="Yes"
                      styleClass="custom-check"
                      GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label fx:id="pregnantLabel"
                   text="Pregnant:"
                   styleClass="form-label"
                   GridPane.rowIndex="7" GridPane.columnIndex="0"
                   visible="false"
                   managed="false"/>
            <CheckBox fx:id="pregnantCheck"
                      text="Yes"
                      styleClass="custom-check"
                      GridPane.rowIndex="7" GridPane.columnIndex="1"
                      visible="false"
                      managed="false"/>

        </GridPane>

        <HBox spacing="20" alignment="CENTER">
            <Button text="Save Profile"
                    fx:id="saveButton"
                    styleClass="primary-btn"/>
            <Button text="Cancel"
                    styleClass="secondary-btn"/>
        </HBox>

        <HBox alignment="CENTER"
              fx:id="successBox"
              styleClass="success-box"
              visible="false"
              managed="false">
            <Label text="✔ Profile saved successfully!"
                   styleClass="success-text"/>
        </HBox>

    </VBox>

</StackPane>