<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="main-background-light" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.aqi.controllers.SignUpController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-nav">
            <Label text="AiQI" styleClass="logo-text"/>
            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="aboutNavBtnSu" text="About Us" onAction="#goToAbout" styleClass="nav-link"/>
            <Button fx:id="loginNavBtn" text="Login" onAction="#goToLogin" styleClass="nav-link"/>
            <Button text="Sign Up" styleClass="nav-btn-login"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER">

            <!-- Back to Dashboard — top-left, only shown when guest is redirected here -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 12 0 0 24;">
                <Button fx:id="backToDashboardBtn" text="← Back to Dashboard"
                        onAction="#handleBackToDashboard"
                        visible="false" managed="false"
                        style="-fx-background-color: #e8f0fe; -fx-text-fill: #1a73e8;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-background-radius: 10; -fx-border-color: #bfdbfe;
                               -fx-border-radius: 10; -fx-border-width: 1;
                               -fx-padding: 8 18; -fx-cursor: hand;"/>
            </HBox>

            <VBox fx:id="signUpCard" styleClass="card-light" alignment="CENTER_LEFT" spacing="15" maxWidth="400" maxHeight="650">

                <Label text="Create Account" styleClass="title-label-light" style="-fx-padding: 0 0 5 0;"/>

                <VBox spacing="4">
                    <Label text="FULL NAME" styleClass="input-label"/>
                    <TextField fx:id="nameField" promptText="Enter your name" styleClass="input-field-light"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="EMAIL ADDRESS" styleClass="input-label"/>
                    <TextField fx:id="emailField" promptText="Enter email" styleClass="input-field-light"/>
                </VBox>

                <VBox spacing="2">
                    <Label text="PASSWORD" styleClass="input-label"/>
                    <PasswordField fx:id="passwordField" promptText="Create password" styleClass="input-field-light"/>
                    <Region fx:id="passStrengthLine" prefHeight="3" style="-fx-background-color: #e5e7eb; -fx-background-radius: 2;" />
                </VBox>

                <VBox spacing="6">
                    <Label text="CONFIRM PASSWORD" styleClass="input-label"/>

                    <StackPane alignment="CENTER_RIGHT">
                        <TextField fx:id="confirmPasswordVisibleField" promptText="Re-enter password" styleClass="input-field-light" visible="false" managed="false"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" styleClass="input-field-light"/>

                        <Button fx:id="toggleConfirmBtn" text="👁" onAction="#toggleConfirmVisibility"
                                style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-cursor: hand; -fx-font-size: 14px;">
                            <StackPane.margin>
                                <Insets right="5"/>
                            </StackPane.margin>
                        </Button>
                    </StackPane>

                    <Region fx:id="confirmPassStrengthLine" prefHeight="3" style="-fx-background-color: transparent;"/>
                </VBox>

                <StackPane alignment="CENTER_LEFT">

                    <VBox fx:id="passwordConditionsBox" spacing="4" visible="false" managed="false">
                        <Label fx:id="lengthLabel" text="✗ At least 8 characters" textFill="#ef4444" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="upperLabel" text="✗ 1 Uppercase letter" textFill="#ef4444" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="lowerLabel" text="✗ 1 Lowercase letter" textFill="#ef4444" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="numberLabel" text="✗ 1 Number" textFill="#ef4444" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <Label fx:id="specialLabel" text="✗ 1 Special character" textFill="#ef4444" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox fx:id="otpBox" spacing="4" visible="false" managed="false">
                        <Label text="VERIFICATION CODE" styleClass="input-label" textFill="#0ea5e9"/>
                        <TextField fx:id="otpInput" promptText="Enter 6-digit OTP from your email" styleClass="input-field-light" style="-fx-border-color: #0ea5e9;"/>
                    </VBox>

                </StackPane>

                <Label fx:id="statusLabel" textFill="#ef4444" wrapText="true" minHeight="20" alignment="TOP_LEFT" maxWidth="Infinity"/>

                <Button fx:id="mainActionBtn" text="Send OTP" onAction="#handleMainAction" styleClass="btn-submit-primary" maxWidth="Infinity"/>

            </VBox>
        </VBox>
    </center>
</BorderPane>
