<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="main-background-light" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.aqi.controllers.ForgotPasswordController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-nav">
            <Label text="AiQI" styleClass="logo-text"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Back to Login ↗" onAction="#goToLogin" styleClass="nav-btn-login"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER">
            <VBox styleClass="card-light" alignment="CENTER_LEFT" spacing="18" maxWidth="380">

                <Label text="Reset Password" styleClass="title-label-light" style="-fx-padding: 0 0 5 0;"/>

                <VBox fx:id="emailBox" spacing="15">
                    <Label text="Enter your registered email address to receive a 6-digit verification code." wrapText="true" style="-fx-text-fill: #666;"/>

                    <VBox spacing="6">
                        <Label text="EMAIL ADDRESS" styleClass="input-label"/>
                        <TextField fx:id="emailField" promptText="name@example.com" styleClass="input-field-light"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;">
                        <Button text="Send OTP" onAction="#handleSendOtp" styleClass="btn-submit-primary" prefWidth="120"/>
                        <Button text="Cancel" onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-cursor: hand; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-padding: 8 16;"/>
                    </HBox>
                </VBox>

                <VBox fx:id="resetBox" spacing="12" visible="false" managed="false">
                    <Label text="We sent a 6-digit code to your email." style="-fx-text-fill: #10b981; -fx-font-weight: bold;"/>

                    <VBox spacing="6">
                        <Label text="ENTER OTP" styleClass="input-label"/>
                        <TextField fx:id="otpField" promptText="123456" styleClass="input-field-light"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="NEW PASSWORD" styleClass="input-label"/>
                        <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="input-field-light"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="CONFIRM PASSWORD" styleClass="input-label"/>

                        <StackPane alignment="CENTER_RIGHT">
                            <TextField fx:id="confirmPasswordVisibleField" promptText="Re-enter password" styleClass="input-field-light" visible="false" managed="false"/>

                            <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" styleClass="input-field-light"/>

                            <Button fx:id="toggleConfirmBtn" text="👁" onAction="#toggleConfirmVisibility"
                                    style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-cursor: hand; -fx-font-size: 14px;">
                                <StackPane.margin>
                                    <Insets right="5"/> </StackPane.margin>
                            </Button>
                        </StackPane>
                    </VBox>

                    <VBox spacing="2">
                        <Label fx:id="lengthLabel" text="• At least 8 characters" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                        <Label fx:id="upperLabel" text="• At least one uppercase letter" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                        <Label fx:id="numberLabel" text="• At least one number" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                        <Label fx:id="specialLabel" text="• At least one special character (@$!%*?&amp;)" style="-fx-text-fill: #888; -fx-font-size: 11px;"/>
                    </VBox>

                    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5 0 0 0;">
                        <Button text="Update Password" onAction="#handleResetPassword" styleClass="btn-submit-primary" prefWidth="140"/>
                        <Button text="Cancel" onAction="#goToLogin" style="-fx-background-color: transparent; -fx-text-fill: #555; -fx-cursor: hand; -fx-border-color: #ccc; -fx-border-radius: 6; -fx-padding: 8 16;"/>
                    </HBox>
                </VBox>

                <Label fx:id="statusLabel" textFill="#ef4444" wrapText="true"/>

            </VBox>
        </VBox>
    </center>
</BorderPane>