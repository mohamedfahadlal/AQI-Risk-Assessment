<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane styleClass="main-background-light" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.aqi.controllers.LoginController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-nav">
            <Label text="AiQI" styleClass="logo-text"/>
            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="aboutNavBtn" text="About Us" onAction="#goToAbout" styleClass="nav-link"/>
            <Button fx:id="signUpNavBtn" text="Sign Up" onAction="#goToSignUp" styleClass="nav-link"/>
            <Button text="Login ↗" styleClass="nav-btn-login"/>
        </HBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="12">
            <VBox fx:id="loginCard" styleClass="card-light" alignment="CENTER_LEFT" spacing="18" maxWidth="380" maxHeight="460">

                <Label text="Welcome Back" styleClass="title-label-light" style="-fx-padding: 0 0 10 0;"/>

                <VBox spacing="6">
                    <Label text="EMAIL ADDRESS" styleClass="input-label"/>
                    <TextField fx:id="emailField" promptText="Enter your email" styleClass="input-field-light"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="PASSWORD" styleClass="input-label"/>
                    <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="input-field-light"/>

                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 2 0 0 0;">
                        <CheckBox fx:id="rememberMeBox" text="Remember me" style="-fx-text-fill: #555; -fx-font-size: 12px; -fx-cursor: hand;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Hyperlink text="Forgot Password?"
                                   fx:id="forgotBtn" onAction="#handleForgotPassword"
                                   style="-fx-text-fill: #007bff; -fx-font-size: 12px; -fx-padding: 0;"/>
                    </HBox>
                </VBox>

                <Label fx:id="statusLabel" textFill="#ef4444" wrapText="true"/>

                <Button fx:id="loginBtn" text="Login to Dashboard" onAction="#handleLogin"
                        styleClass="btn-submit-primary" maxWidth="Infinity"/>

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="10">
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-border-color: #cbd5e1; -fx-border-width: 1 0 0 0; -fx-pref-height: 1;"/>
                    <Label text="or" style="-fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"
                            style="-fx-border-color: #cbd5e1; -fx-border-width: 1 0 0 0; -fx-pref-height: 1;"/>
                </HBox>

                <!-- Guest login -->
                <Button fx:id="guestBtn" text="Continue as Guest" onAction="#handleGuestLogin"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-border-color: #94a3b8;
                               -fx-border-radius: 8; -fx-background-radius: 8; -fx-border-width: 1.5;
                               -fx-text-fill: #64748b; -fx-font-size: 13px;
                               -fx-padding: 10 24; -fx-cursor: hand;"/>

            </VBox>
        </VBox>
    </center>
</BorderPane>
